# =========================================================================
# CachePanel v1.7+ — minimal .env
# =========================================================================
#
# Starting in v1.7, almost all configuration moves to the SQLite database
# and is editable from the in-panel /setup wizard or /settings page.
# Only the variables BELOW are still read from .env at boot time.
#
# Everything that used to live here (Discord OAuth, SSH-to-host, Cloudflare
# API, Ollama, terminal config, file-manager scoping, etc.) is now stored
# in AppSetting rows and edited from the panel. See the bottom of this file
# for the legacy var list — they still work as a fallback so v1.6 installs
# keep running unchanged, but new installs should leave them blank.

# --- Database (SQLite) ---
# Under Docker Compose this is overridden to point at /app/data/cachepanel.db
# inside the container, which is backed by a named volume.
# For local development, a relative path works fine.
DATABASE_URL=file:./prisma/cachepanel.db

# --- NextAuth (boot-required) ---
# Public URL where browsers will reach the panel. NextAuth reads this at
# module load — changing it requires editing this file and restarting.
NEXTAUTH_URL=http://localhost:8992
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Trust X-Forwarded-* headers from Cloudflare Tunnel / Nginx so the
# callback host matches NEXTAUTH_URL.
AUTH_TRUST_HOST=true

# --- App ---
APP_PORT=8992

# --- First-run setup token (auto-generated by install.sh) -----------------
# Random hex string. Used by /setup on first boot to claim OWNER. The panel
# prints the full /setup?token=… URL in docker logs at startup while
# setup is still incomplete. Delete this line once setup is finished —
# the token is no longer used and the panel will silently ignore it.
CP_SETUP_TOKEN=

# =========================================================================
# Legacy v1.6 vars — DEPRECATED.
# =========================================================================
#
# These all still work as a fallback (config.ts reads AppSetting first,
# then falls back to env). On first boot of v1.7+, any value set below is
# automatically migrated into AppSetting and you can delete the key from
# this file after the next restart. The migration log tells you exactly
# which keys it migrated.
#
# New installs: leave everything below blank and configure from /setup.

# --- Discord OAuth (now: /setup wizard or Settings → Discord) ---
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_GUILD_ID=
# DISCORD_ALLOWED_ROLE_IDS=
# DISCORD_ALLOWED_USER_IDS=

# --- Approval policy (now: Settings → Access) ---
# ADMIN_CAN_APPROVE_USERS=false

# --- File manager (now: Settings → File manager) ---
# ALLOWED_FILE_ROOTS=
# ALLOW_DOTENV_ACCESS=false

# --- Terminal (now: Settings → Terminal) ---
# TERMINAL_ENABLED=true
# TERMINAL_SHELL=/bin/bash
# TERMINAL_USER=cache
# TERMINAL_START_DIR=/home/cache
# TERMINAL_AUDIT_COMMANDS=false

# --- SSH-to-host (now: Settings → SSH-to-host) ---
# SSH_HOST=
# SSH_PORT=22
# SSH_USER=
# SSH_KEY_PATH=/run/secrets/cachepanel_id_ed25519
# SSH_KNOWN_HOSTS=/run/secrets/known_hosts

# --- AI assistant (now: Settings → Assistant) ---
# OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_MODEL=mistral

# --- Cloudflare Tunnel API (now: /setup wizard or Settings → Cloudflare) ---
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
