# --- Database (SQLite) ---
# Under Docker Compose this is overridden to point at /app/data/cachepanel.db
# inside the container, which is backed by a named volume.
# For local development, a relative path works fine.
DATABASE_URL=file:./prisma/cachepanel.db

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:8992
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Discord OAuth ---
# Create application at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Optional: restrict login to members of a single Discord guild
DISCORD_GUILD_ID=
# Optional: comma-separated list of Discord role IDs allowed to log in
DISCORD_ALLOWED_ROLE_IDS=
# Optional: comma-separated allowlist of Discord user IDs. If set, ONLY these
# users may log in — every other Discord account is rejected before any user
# record is created. Right-click a user in Discord (Dev Mode on) → Copy User ID.
DISCORD_ALLOWED_USER_IDS=

# --- Approval Policy ---
# If true, ADMIN users may approve PENDING users (only as ADMIN; never as OWNER).
ADMIN_CAN_APPROVE_USERS=false

# --- File Manager ---
# Comma-separated list of absolute paths that the file manager is allowed to
# read/write. Leave BLANK to allow the entire filesystem (sensitive files
# like /etc/shadow, private SSH keys, and .env files are still blocked).
ALLOWED_FILE_ROOTS=
# If true, OWNER can browse .env files inside allowed roots. Strongly discouraged.
ALLOW_DOTENV_ACCESS=false

# --- Terminal ---
TERMINAL_ENABLED=true
TERMINAL_SHELL=/bin/bash
TERMINAL_USER=cache
TERMINAL_START_DIR=/home/cache
# If true, every command typed into the terminal is written to the audit log.
TERMINAL_AUDIT_COMMANDS=false

# --- SSH-to-host mode (recommended in Docker) ---
# When SSH_HOST is set, the terminal connects to your real server via SSH
# instead of spawning a shell inside the container. This gives you a real
# session on the host (systemctl, apt, /etc, your home directory, the works).
#
# Setup (one-time, on the host):
#   1. Create a Linux account if you don't already have one — e.g. `cache_admin`
#   2. Append CachePanel's public key to ~cache_admin/.ssh/authorized_keys
#      (the key lives in ./secrets/cachepanel_id_ed25519.pub after first run)
#   3. Make sure SSH is reachable from inside Docker:
#        ufw allow from 172.16.0.0/12 to any port 22
#
# Connecting from Docker: 'host.docker.internal' resolves to the host on
# Docker Desktop (Mac/Windows). On Linux, add this to docker-compose.yml:
#   extra_hosts:
#     - "host.docker.internal:host-gateway"
# (already configured in the provided docker-compose.yml).
SSH_HOST=
SSH_PORT=22
SSH_USER=
# Path *inside the container* to the private key. The Compose file mounts
# ./secrets/ → /run/secrets/, so the default below works once you generate keys.
SSH_KEY_PATH=/run/secrets/cachepanel_id_ed25519
# Path *inside the container* to a known_hosts file (prevents MITM). Generate
# once with:
#   ssh-keyscan -p $SSH_PORT $SSH_HOST > ./secrets/known_hosts
SSH_KNOWN_HOSTS=/run/secrets/known_hosts

# --- App ---
APP_PORT=8992

# --- AI assistant (Ollama) ---
# CachePanel queries Ollama for the /assistant page. By default it reaches
# the host's Ollama via host.docker.internal — install Ollama on the host
# and `ollama pull mistral` so the default model works out of the box.
#
# Make sure Ollama listens on 0.0.0.0 so the container can reach it:
#   sudo systemctl edit ollama
#   [Service]
#   Environment="OLLAMA_HOST=0.0.0.0:11434"
#   sudo systemctl restart ollama
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=mistral

# --- Cloudflare Tunnel ---
# Create an API token at:
#   https://dash.cloudflare.com/profile/api-tokens
# Permissions:
#   Account · Cloudflare Tunnel · Edit
#   Zone    · DNS               · Edit   (only if you want CachePanel to manage public hostname DNS)
# Account ID is on the Cloudflare dashboard right sidebar of any zone overview.
# When unset, the Tunnels page shows a configuration prompt.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
