generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Role is one of "OWNER" | "ADMIN" — enforced at the TypeScript layer
// because SQLite doesn't support native enums.
// UserStatus is one of "PENDING" | "APPROVED" | "DISABLED".

model User {
  id          String    @id @default(cuid())
  discordId   String    @unique
  username    String
  avatar      String?
  email       String?
  role        String    @default("ADMIN")
  status      String    @default("PENDING")
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Per-user SSH (Option A). When `sshAccess` is true, CachePanel has
  // provisioned a Linux account on the host and the browser terminal SSHes
  // as that user. `sshSudo` enables passwordless sudo for them.
  sshUsername    String?
  sshAccess      Boolean @default(false)
  sshSudo        Boolean @default(false)
  sshProvisioned Boolean @default(false)

  auditLogs        AuditLog[]
  terminalSessions TerminalSession[]
  fileActions      FileAction[]
  authenticators   Authenticator[]
  recoveryCodes    RecoveryCode[]
  installedApps    InstalledApp[]

  @@index([role])
  @@index([status])
}

// WebAuthn second factor. Optional today; required to grant the ADMIN role
// once any OWNER has one enrolled.
model Authenticator {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId        Bytes     @unique
  credentialPublicKey Bytes
  counter             Int       @default(0)
  transports          String    @default("") // CSV: "usb,nfc,ble,internal"
  nickname            String
  createdAt           DateTime  @default(now())
  lastUsedAt          DateTime?

  @@index([userId])
}

// Bcrypt-hashed one-time recovery codes printed during enrollment. 10 per
// enrollment; each row consumed once.
model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hash      String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  target    String?
  // JSON-encoded string (SQLite has no native JSON column).
  metadata  String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model TerminalSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt DateTime @default(now())
  endedAt   DateTime?
  ipAddress String?
  status    String   @default("active")

  @@index([userId])
  @@index([status])
}

model FileAction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  path      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// Multi-server: every host CachePanel can manage. The first row is auto-
// created as the "primary" — the box CachePanel itself runs on — and is
// flagged isPrimary=true. Primary's metadata is locked in the UI.
model Server {
  id             String   @id @default(cuid())
  name           String   @unique
  hostname       String
  port           Int      @default(22)
  defaultUser    String
  // Filename inside ./secrets/ for the global SSH key + known_hosts.
  // (Per-user provisioned accounts override this on a per-(user,server) basis.)
  keyName        String   @default("cachepanel_id_ed25519")
  knownHostsName String   @default("known_hosts")
  // Comma-separated freeform tags for grouping in the picker.
  tags           String   @default("")
  isPrimary      Boolean  @default(false)
  notes          String?
  addedById      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  provisions     UserServerProvision[]
  installedApps  InstalledApp[]
  snapshots      ServerSnapshot[]
  scheduledJobs  ScheduledJob[]

  @@index([isPrimary])
}

// User-managed cron jobs. We write them to the SSH user's crontab tagged
// with the row id so we can edit/remove later. We don't try to model arbitrary
// existing crontab entries — only ones the panel created.
model ScheduledJob {
  id            String   @id @default(cuid())
  serverId      String
  server        Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  name          String
  cronExpr      String   // 5-field crontab: "0 3 * * *"
  command       String
  enabled       Boolean  @default(true)
  lastOutput    String?  // captured stdout/stderr of last run if user opted in
  lastExitCode  Int?
  lastRanAt     DateTime?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([serverId])
}

// Time-series rows written by the alert-poller every 60s. Used to draw the
// per-server health charts. Rows older than 7 days are pruned by the same
// poller (cheap; no separate cron).
model ServerSnapshot {
  id         String   @id @default(cuid())
  serverId   String
  server     Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  cpuPct     Float?
  memPct     Float?
  diskPct    Float?
  loadAvg1   Float?
  reachable  Boolean  @default(true)
  recordedAt DateTime @default(now())

  @@index([serverId, recordedAt])
}

// One-click app installations. Each row tracks a docker-compose-managed app
// dropped under /opt/cachepanel/apps/<slug> on a target Server. v1 allows
// exactly one install per (server, slug); multi-instance can come later.
model InstalledApp {
  id            String   @id @default(cuid())
  serverId      String
  server        Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  slug          String
  name          String
  status        String   @default("installing") // installing|running|stopped|failed|removing
  variables     String   // JSON {name: value}; secrets included
  composeYaml   String
  ports         String   @default("[]") // JSON: [{public:8080, container:80}]
  imageTag      String   @default("")
  hasUpdate     Boolean  @default(false)
  installedById String?
  installedBy   User?    @relation(fields: [installedById], references: [id], onDelete: SetNull)
  installedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([serverId, slug])
  @@index([serverId])
}

// Per-(user,server) provisioning state. When OWNER clicks "provision SSH" for
// a user on a given server, we create one of these rows so the terminal knows
// which Linux account to SSH as for that user on that host.
model UserServerProvision {
  id           String   @id @default(cuid())
  userId       String
  serverId     String
  sshUsername  String
  sshSudo      Boolean  @default(false)
  provisioned  Boolean  @default(false)
  lastError    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([userId, serverId])
  @@index([serverId])
}

// Saved database connection profiles (DB management section).
// `password` is stored encrypted with NEXTAUTH_SECRET-derived AES-256-GCM.
model DbConnection {
  id          String   @id @default(cuid())
  name        String
  // 'mysql' | 'mariadb' | 'postgres' | 'sqlite'
  driver      String
  host        String?
  port        Int?
  username    String?
  password    String?   // ciphertext, nullable for sqlite
  database    String?   // for sqlite this is an absolute file path
  ssl         Boolean   @default(false)
  // OWNER-only when true (ADMINs can't open this profile at all)
  ownerOnly   Boolean   @default(false)
  // OWNER-only when true (everyone can connect, but no one can run write queries)
  readOnly    Boolean   @default(false)
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([driver])
}
